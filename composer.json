{
    "name": "nabesaka/composer-preview",
    "description": "Allows displaying of a preview of the topic content when creating a new topic.",
    "type": "flarum-extension",
    "require": {
      "flarum/core": "^1.0.0"
    },
    "autoload": {
      "psr-4": {
        "Nabesaka\\ComposerPreview\\": "src/"
      }
    },
    "extra": {
      "flarum-extension": {
        "title": "Composer Preview",
        "icon": {
          "name": "fas fa-eye",
          "backgroundColor": "#f44336",
          "color": "#fff"
        }
      }
    }
  }